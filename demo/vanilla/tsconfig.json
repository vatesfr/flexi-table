{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "@vates/flexi-table-core": ["../../packages/core/src/index.ts"],
      "@vates/flexi-table-core/locales": ["../../packages/core/src/locales.ts"],
      "@vates/flexi-table-vanilla": ["../../packages/vanilla/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
