{
  "name": "@vates/flexi-table-react",
  "version": "0.1.0",
  "description": "React adapter for flexi-table",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vates/flexi-table.git",
    "directory": "packages/react"
  },
  "keywords": ["table", "datatable", "sort", "filter", "group", "react", "typescript"],
  "engines": { "node": ">=18" },
  "type": "module",
  "main": "./dist/flexi-table-react.umd.cjs",
  "module": "./dist/flexi-table-react.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flexi-table-react.js",
      "require": "./dist/flexi-table-react.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vates/flexi-table-core": "*"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0"
  }
}
