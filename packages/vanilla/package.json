{
  "name": "@vates/flexi-table-vanilla",
  "version": "0.1.0",
  "description": "Vanilla JS adapter for flexi-table",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vatesfr/flexi-table.git",
    "directory": "packages/vanilla"
  },
  "keywords": [
    "table",
    "datatable",
    "sort",
    "filter",
    "group",
    "vanilla",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/flexi-table-vanilla.umd.cjs",
  "module": "./dist/flexi-table-vanilla.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flexi-table-vanilla.js",
      "require": "./dist/flexi-table-vanilla.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vates/flexi-table-core": "*"
  },
  "devDependencies": {
    "jsdom": "^25.0.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vitest": "^2.1.9"
  }
}
