{
  "name": "@vates/flexi-table-vue",
  "version": "0.1.0",
  "description": "Vue 3 adapter for flexi-table",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vates/flexi-table.git",
    "directory": "packages/vue"
  },
  "keywords": ["table", "datatable", "sort", "filter", "group", "vue", "vue3", "typescript"],
  "engines": { "node": ">=18" },
  "type": "module",
  "main": "./dist/flexi-table-vue.umd.cjs",
  "module": "./dist/flexi-table-vue.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/flexi-table-vue.js",
      "require": "./dist/flexi-table-vue.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "vite build",
    "type-check": "vue-tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vates/flexi-table-core": "*"
  },
  "peerDependencies": {
    "vue": ">=3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.2.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}
